      "name": "CrearItems",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var response = pm.response.json();\r",
              "pm.collectionVariables.set(\"ITEMS_ID\", response.Id);\r",
              "\r",
              "pm.test(\"Verifica Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Verifica Items name\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.Content).to.eql(\"Jmeter Leidyenith\");\r",
              "});\r",
              "\r",
              "pm.test(\"Verifica Items type\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.ItemType).to.eql(1);\r",
              "});"
            ],
